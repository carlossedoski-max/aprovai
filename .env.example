# ==========================================
# APROVAI — Environment Variables
# ==========================================
# Copie este arquivo para .env.local e preencha os valores

# ------------------------------------------
# DATABASE (PostgreSQL via Neon ou Supabase)
# ------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/aprovai?sslmode=require"

# ------------------------------------------
# CLERK AUTH
# ------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/entrar
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/cadastro
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ------------------------------------------
# STRIPE (para usuários internacionais)
# ------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_MONTHLY_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_SEMIANNUAL_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_LIFETIME_PRICE_ID=price_xxxxxxxxxxxx

# ------------------------------------------
# MERCADO PAGO (para usuários brasileiros)
# ------------------------------------------
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxxxxxx
MERCADOPAGO_WEBHOOK_SECRET=xxxxxxxxxxxx
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxxxxxx

# ------------------------------------------
# OPENAI (IA Tutor)
# ------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ------------------------------------------
# CLOUDINARY (uploads de imagem/PDF)
# ------------------------------------------
CLOUDINARY_CLOUD_NAME=xxxxxxxxxxxx
CLOUDINARY_API_KEY=xxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxx
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=xxxxxxxxxxxx

# ------------------------------------------
# APP CONFIG
# ------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Aprovai
NODE_ENV=development
